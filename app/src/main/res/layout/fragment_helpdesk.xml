<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:animateLayoutChanges="true">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enrolamiento HelpDesk"
            android:textAppearance="?attr/textAppearanceHeadlineMedium"
            android:textColor="@color/primary"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Correo Institucional"
            android:layout_marginBottom="16dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCorreoInstitucional"
                android:inputType="textEmailAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Método de Identificación:"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/rgMetodo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">
            <RadioButton android:id="@+id/rbNomina" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nómina" />
            <RadioButton android:id="@+id/rbFoto" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Foto (IA)" />
            <RadioButton android:id="@+id/rbEventual" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Eventual" />
        </RadioGroup>

        <LinearLayout
            android:id="@+id/llContainerNomina"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Número de Nómina">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNominaBusqueda"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBuscarNomina"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:text="BUSCAR EMPLEADO" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/llContainerFoto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTomarFoto"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="ABRIR CÁMARA"
                app:icon="@android:drawable/ic_menu_camera" />

            <ImageView
                android:id="@+id/ivFotoPreview"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:layout_gravity="center"
                android:layout_marginTop="8dp"
                android:scaleType="centerCrop"
                android:visibility="gone"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnProcesarIA"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:text="ANALIZAR CON IA Y BIOMETRÍA"
                android:visibility="gone"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/llContainerEventual"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <EditText android:id="@+id/etEvNombre" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Nombre Completo"/>
            <EditText android:id="@+id/etEvCurp" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="CURP"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fecha de Permanencia (Vigencia):" android:layout_marginTop="8dp"/>
            <EditText android:id="@+id/etEvFechaTermino" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="YYYY-MM-DD" android:inputType="date"/>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cvResultado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="#E3F2FD"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView android:id="@+id/tvResGenerales" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@android:color/black"/>

                <ImageView android:id="@+id/ivResFoto" android:layout_width="100dp" android:layout_height="100dp" android:layout_marginTop="8dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGuardarAuditoria"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="16dp"
                    android:text="GUARDAR Y CONTINUAR (ESTADO: OPEN)" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>